datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Position {
  id        String   @id @default(cuid())
  ticker    String
  name      String
  type      String   // "stock" | "etf" | "crypto" | "cash"
  quantity  Float
  avgPrice  Float
  currency  String   @default("USD")
  sector    String?
  country   String?
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(cuid())
  ticker    String
  type      String   // "buy" | "sell" | "dividend"
  quantity  Float
  price     Float
  date      DateTime
  fees      Float    @default(0)
  createdAt DateTime @default(now())
}
